{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "picodb:artifact:curation:v1.0.0",
  "title": "CurationArtifact",
  "description": "Decides whether and how a source should appear in the portal. Distinguishes serious scholarly content from pop-occult, AI spam, or lifestyle content. Stage F. publish/feature decisions MUST include reasons_for_inclusion.",
  "type": "object",
  "required": ["artifact_id", "artifact_type", "schema_version", "source_id", "generated_at", "input_artifact_ids", "relevance_status"],
  "additionalProperties": false,
  "properties": {
    "artifact_id":       { "type": "string", "description": "cur_{source_shortcode}_{seq}" },
    "artifact_type":     { "type": "string", "const": "curation" },
    "schema_version":    { "type": "string", "const": "1.0.0" },
    "source_id":         { "type": "string" },
    "generated_at":      { "type": "string", "format": "date-time" },
    "generating_agent":  { "type": "string" },
    "input_artifact_ids": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "relevance_status": {
      "type": "string",
      "enum": ["reject", "archive", "review", "publish", "feature"]
    },
    "relevance_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "0=irrelevant, 1=essential"
    },
    "audience_fit": {
      "type": "string",
      "enum": ["specialist", "advanced_general", "general", "not_applicable"]
    },
    "scholarly_value": {
      "type": "string",
      "enum": ["high", "medium", "low", "not_applicable"]
    },
    "content_quality_flags": {
      "type": "array",
      "description": "Quality signals used in curation decision",
      "items": {
        "type": "string",
        "enum": [
          "serious_scholarship", "peer_reviewed", "primary_source_discussion",
          "edition_or_translation", "revisionary_argument", "specialist_audience",
          "popular_scholarship", "accessible_introduction",
          "pop_occult", "lifestyle_spirituality", "vague_spirituality",
          "ai_generated_spam", "low_scholarly_relevance", "unverifiable_claims",
          "conspiracy_adjacent", "sensationalist"
        ]
      }
    },
    "reasons_for_inclusion": {
      "type": "array",
      "description": "REQUIRED when relevance_status is publish or feature",
      "items": { "type": "string" }
    },
    "reasons_for_exclusion": {
      "type": "array",
      "items": { "type": "string" }
    },
    "recommended_tags": { "type": "array", "items": { "type": "string" } },
    "editorial_angle":  { "type": "string" },
    "curator_notes":    { "type": "string" }
  },
  "if": {
    "properties": { "relevance_status": { "enum": ["publish", "feature"] } }
  },
  "then": {
    "required": ["reasons_for_inclusion"],
    "properties": {
      "reasons_for_inclusion": { "type": "array", "minItems": 1 }
    }
  }
}
