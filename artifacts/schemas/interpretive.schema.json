{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "picodb:artifact:interpretive:v1.0.0",
  "title": "InterpretiveArtifact",
  "description": "Makes bounded scholarly interpretations from prior descriptive and tagging artifacts. Every interpretive claim must have evidence_links or be explicitly marked speculative. Stage E.",
  "type": "object",
  "required": ["artifact_id", "artifact_type", "schema_version", "source_id", "generated_at", "input_artifact_ids"],
  "additionalProperties": false,
  "properties": {
    "artifact_id":        { "type": "string", "description": "int_{source_shortcode}_{topic}_{seq}" },
    "artifact_type":      { "type": "string", "const": "interpretive" },
    "schema_version":     { "type": "string", "const": "1.0.0" },
    "source_id":          { "type": "string" },
    "generated_at":       { "type": "string", "format": "date-time" },
    "generating_agent":   { "type": "string" },
    "input_artifact_ids": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" },
      "description": "IDs of raw_extraction and/or ontology_tagging artifacts consumed"
    },
    "interpretive_questions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "interpretive_claims": {
      "type": "array",
      "description": "Each claim must have evidence_links or confidence=speculative",
      "items": {
        "type": "object",
        "required": ["claim_id", "claim_text", "confidence"],
        "properties": {
          "claim_id":         { "type": "string" },
          "claim_text":       { "type": "string" },
          "evidence_links": {
            "type": "array",
            "description": "Source locations supporting this claim",
            "items": {
              "type": "object",
              "required": ["source_id"],
              "properties": {
                "source_id":  { "type": "string" },
                "page":       { "type": ["integer", "string"] },
                "quote":      { "type": "string" },
                "artifact_id":{ "type": "string" }
              }
            }
          },
          "confidence": {
            "type": "string",
            "enum": ["high", "medium", "low", "speculative"],
            "description": "speculative claims require no evidence_links but must be flagged clearly"
          },
          "alternative_reading": { "type": "string" },
          "limitations":         { "type": "string" },
          "claim_type": {
            "type": "string",
            "enum": ["interpretive", "historiographical", "open_problem", "synthetic"]
          }
        }
      }
    },
    "historiographical_relevance": { "type": "string" },
    "limitations":                 { "type": "string" },
    "interpretation_notes":        { "type": "string" }
  }
}
