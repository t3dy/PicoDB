{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "picodb:artifact:ontology_tagging:v1.0.0",
  "title": "OntologyTaggingArtifact",
  "description": "Maps a raw extraction onto the portal's controlled vocabulary. Classifies; does not write public prose. Stage D.",
  "type": "object",
  "required": ["artifact_id", "artifact_type", "schema_version", "source_id", "generated_at", "input_artifact_id"],
  "additionalProperties": false,
  "properties": {
    "artifact_id":       { "type": "string", "description": "ot_{source_shortcode}_{section}_{seq}" },
    "artifact_type":     { "type": "string", "const": "ontology_tagging" },
    "schema_version":    { "type": "string", "const": "1.0.0" },
    "source_id":         { "type": "string" },
    "generated_at":      { "type": "string", "format": "date-time" },
    "generating_agent":  { "type": "string" },
    "input_artifact_id": { "type": "string", "description": "ID of the raw_extraction artifact being tagged" },
    "ontology_version":  { "type": "string", "description": "Version of data/pico_ontology.json or reading_artifact_ontology.json used" },
    "traditions": {
      "type": "array",
      "description": "Western-esotericism domain tags",
      "items": {
        "type": "string",
        "enum": [
          "western_esotericism", "renaissance_magic", "alchemy", "hermetism", "neoplatonism",
          "christian_kabbalah", "jewish_kabbalah", "grimoires", "ritual_magic", "astrology",
          "natural_magic", "theurgy", "witchcraft_studies", "history_of_science",
          "manuscript_studies", "book_history", "iconography", "scholasticism",
          "humanism", "arabic_philosophy", "jewish_philosophy", "christian_theology",
          "historiography", "methodology", "primary_source_discussion", "pop_occult"
        ]
      }
    },
    "periods": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["ancient", "late_antique", "medieval", "quattrocento", "cinquecento",
                 "early_modern", "modern", "contemporary"]
      }
    },
    "genres": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["monograph", "article", "chapter", "edition", "translation", "commentary",
                 "letter", "disputation", "oration", "poem", "biography", "reference_work",
                 "anthology", "database"]
      }
    },
    "methods": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["philological", "intellectual_history", "source_criticism", "reception_history",
                 "historiographical_critique", "biographical", "textual_comparison",
                 "codicological", "prosopographical", "quantitative"]
      }
    },
    "historiographical_categories": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["myth_debunking", "source_reconstruction", "formation_history",
                 "reception_history", "concord_argument", "anti_mythic_reconstruction",
                 "corpus_control", "edition_history", "kabbalah_philology"]
      }
    },
    "tags": {
      "type": "array",
      "description": "Portal ontology term IDs from data/pico_ontology.json",
      "items": {
        "type": "object",
        "required": ["tag_id", "label"],
        "properties": {
          "tag_id":     { "type": "string" },
          "label":      { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    },
    "entities_linked": {
      "type": "array",
      "description": "Named entities linked to portal entity IDs",
      "items": {
        "type": "object",
        "required": ["name", "entity_id"],
        "properties": {
          "name":      { "type": "string" },
          "entity_id": { "type": "string" },
          "type":      { "type": "string" }
        }
      }
    },
    "rejected_tags": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["tag", "reason"],
        "properties": {
          "tag":    { "type": "string" },
          "reason": { "type": "string" }
        }
      }
    },
    "scholarly_value": {
      "type": "string",
      "enum": ["high", "medium", "low", "not_applicable"]
    },
    "pop_occult_flag": {
      "type": "boolean",
      "description": "True if content is generic lifestyle occultism with low scholarly value",
      "default": false
    },
    "tagging_notes": { "type": "string" }
  }
}
