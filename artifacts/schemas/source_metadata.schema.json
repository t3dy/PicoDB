{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "picodb:artifact:source_metadata:v1.0.0",
  "title": "SourceMetadataArtifact",
  "description": "Represents an ingested source before any interpretation. Stage A of the artifact pipeline.",
  "type": "object",
  "required": ["artifact_id", "artifact_type", "schema_version", "source_id", "generated_at"],
  "additionalProperties": false,
  "properties": {
    "artifact_id":      { "type": "string", "description": "Globally unique ID: sm_{source_shortcode}_{seq}" },
    "artifact_type":    { "type": "string", "const": "source_metadata" },
    "schema_version":   { "type": "string", "const": "1.0.0" },
    "source_id":        { "type": "string", "description": "Stable identifier used across all artifacts for this source" },
    "generated_at":     { "type": "string", "format": "date-time" },
    "generating_agent": { "type": "string" },
    "source_type": {
      "type": "string",
      "enum": ["pdf", "book", "article", "podcast_episode", "youtube_video", "webpage",
               "manuscript", "database_record", "other"]
    },
    "source_title":      { "type": "string" },
    "authors":           { "type": "array", "items": { "type": "string" } },
    "editors":           { "type": "array", "items": { "type": "string" } },
    "translators":       { "type": "array", "items": { "type": "string" } },
    "publication_date":  { "type": "string" },
    "publisher":         { "type": "string" },
    "place_of_publication": { "type": "string" },
    "series":            { "type": "string" },
    "edition":           { "type": "string" },
    "isbn_or_doi":       { "type": "string" },
    "journal":           { "type": "string", "description": "Journal name for articles" },
    "volume":            { "type": "string" },
    "issue":             { "type": "string" },
    "page_range":        { "type": "string", "description": "Page range within a journal or edited volume, e.g. '444-479'" },
    "source_uri":        { "type": "string" },
    "local_path":        { "type": "string" },
    "ingestion_date":    { "type": "string", "format": "date" },
    "language":          { "type": "string" },
    "rights_status":     { "type": "string", "enum": ["in-copyright", "public-domain", "open-access", "unknown"] },
    "access_notes":      { "type": "string" },
    "raw_text_available":     { "type": "boolean" },
    "transcript_available":   { "type": "boolean" },
    "total_pages":       { "type": "integer" },
    "total_words":       { "type": "integer" },
    "db_document_id":    { "type": ["integer", "null"], "description": "Row id in pico.db documents table, if ingested" },
    "notes":             { "type": "string" }
  }
}
